HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/travel_moments?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# 首次启动若无任何 admin 用户，自动创建一个。生产环境务必修改密码。
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

SIGNED_URL_TTL=1h
SIGNED_URL_CACHE_TTL=55m

# OSS_BACKEND: aliyun | local | (空则 auto：有 endpoint/bucket/key 走 aliyun，否则 local)
OSS_BACKEND=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_UPLOAD_CALLBACK_URL=
OSS_MPS_CALLBACK_URL=

# 阿里云 IMS 智能媒体服务（HLS 多分辨率转码）
# 留空则视频不实际转码，浏览器直接播原 mp4（已能用）
IMS_ENDPOINT=ice.cn-shanghai.aliyuncs.com
IMS_TEMPLATE_GROUP_ID=
IMS_CALLBACK_SECRET=
IMS_HLS_PREFIX=hls/

# 本地 mock 后端：文件落盘目录、对外 URL 前缀（留空则走相对路径，同源）
OSS_LOCAL_DATA_DIR=./data/oss
OSS_LOCAL_PUBLIC_BASE_URL=
OSS_LOCAL_SIGNING_KEY=
